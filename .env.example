# Copy to .env for local development with docker-compose

# PostgreSQL (default)
DATABASE_URL=postgresql://demo:demo@localhost:5433/demo

# MySQL (uncomment to switch)
# DATABASE_URL=mysql://demo:demo@localhost:3307/demo

# Optional: multi-source TOML instead of single URL
# MCP_SQL_CONFIG=./mcp-sql-rust.toml

# Logging (stderr only — never log full DSNs in production)
# MCP_SQL_LOG=info
