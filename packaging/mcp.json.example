{
  "mcpServers": {
    "mcp-sql-rust": {
      "type": "stdio",
      "command": "node",
      "args": [
        "/absolute/path/to/mcp-sql-rust/packaging/cursor-mcp-launcher.mjs",
        "${workspaceFolder}"
      ],
      "env": {
        "MCP_SQL_RUST_BIN": "/home/you/.cargo/bin/mcp-sql-rust",
        "MCP_SQL_ARGS": "--allow-writes --full-tools"
      }
    }
  }
}
